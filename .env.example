# 环境变量配置示例
# 复制此文件为 .env 并修改为你自己的配置

# ============================================
# 模型配置
# ============================================

# 单模态模型文件路径
# 支持 .pth (PyTorch), .onnx (ONNX), .rknn (RKNN) 格式
MODEL_SINGLE_PATH=models/single_model.pth

# 融合模态模型文件路径
# 支持 .pth (PyTorch), .onnx (ONNX), .rknn (RKNN) 格式
MODEL_FUSION_PATH=models/fusion_model.pth

# ============================================
# 服务器配置
# ============================================

# 服务器监听地址
# 127.0.0.1 - 仅本地访问（开发环境）
# 0.0.0.0   - 允许外部访问（生产环境）
HOST=127.0.0.1

# 服务器监听端口
PORT=8000

# ============================================
# 日志配置（新增）
# ============================================

# 日志级别
# DEBUG    - 详细调试信息（开发环境）
# INFO     - 一般信息（推荐）
# WARNING  - 警告信息
# ERROR    - 错误信息
# CRITICAL - 严重错误
LOG_LEVEL=INFO

# 是否使用 JSON 格式日志
# true  - 输出 JSON 格式，便于 ELK 等日志分析工具采集
# false - 输出人类可读格式（推荐开发环境）
# 默认：false
LOG_JSON_FORMAT=false

# 是否记录请求体（生产环境建议关闭，避免泄露敏感信息）
# true  - 记录 POST/PUT/PATCH 请求的请求体
# false - 不记录请求体
# 默认：false
LOG_REQUEST_BODY=false

# 是否记录响应体（生产环境建议关闭，避免日志过大）
# true  - 记录响应体
# false - 不记录响应体
# 默认：false
LOG_RESPONSE_BODY=false

# 是否启用审计日志
# true  - 启用审计日志，记录关键操作
# false - 禁用审计日志
# 默认：true
AUDIT_LOG_ENABLED=true

# 注意：日志仅输出到文件（logs/目录），不输出到控制台
# 普通日志：logs/{timestamp}.log
# 审计日志：logs/{timestamp}_audit.log（JSON 格式）
# 默认：true
AUDIT_LOG_ENABLED=true

# ============================================
# 推理配置
# ============================================

# 推理设备
# cuda - 使用 GPU（需要 CUDA 支持）
# cpu  - 使用 CPU
DEVICE=cuda

# 模型输入尺寸
# 输入图像将被调整为该尺寸（正方形）
# 默认：112
INPUT_SIZE=112

# ============================================
# 认证与安全配置（新增）
# ============================================

# JWT 密钥（生产环境务必修改为随机生成的安全密钥）
# 生成方法：python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=your-secret-key-change-in-production

# JWT Token 过期时间（小时）
# 默认：24 小时
JWT_EXPIRATION_HOURS=24

# 管理员账户（用于 JWT Token 登录，管理激活码）
# 生产环境务必修改为强密码
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-admin-password-change-in-production

# 默认激活码（仅用于开发环境测试）
# 生产环境应通过 /auth/activation-codes 端点创建新的激活码
DEFAULT_ACTIVATION_CODE=ACT-DEV-DEFAULT-KEY

# ============================================
# 调试模式配置（新增）
# ============================================

# 启用调试模式（无需模型文件）
# true  - 使用虚拟推理器，生成随机结果（适合开发测试/前端联调）
# false - 使用真实模型推理（需要模型文件）
# 默认：false
DEBUG_MODE=false

# 单模态图像处理延迟（秒）
# 调试模式下每张图像的模拟处理时间
# 默认：0.5
DEBUG_DELAY_PER_IMAGE=0.5

# 融合模态图像处理延迟（秒）
# 调试模式下每对图像的模拟处理时间
# 默认：0.8
DEBUG_DELAY_PER_PAIR=0.8

# ============================================
# 配置说明
# ============================================
#
# 1. 复制此文件：
#    cp .env.example .env
#
# 2. 修改 .env 中的值
#
# 3. 环境变量优先级高于 .env 文件：
#    export DEVICE=cpu
#    python main.py
#
# 4. 如果 .env 文件不存在，将使用上述默认值
#
# 5. 认证配置说明：
#    - JWT_SECRET_KEY 和 ADMIN_PASSWORD 生产环境务必修改
#    - DEFAULT_ACTIVATION_CODE 仅用于开发测试
#    - API Key 通过激活码换取，不需要预设
#
# ============================================
