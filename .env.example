# 环境变量配置示例
# 复制此文件为 .env 并修改为你自己的配置

# ============================================
# 模型配置
# ============================================

# 单模态模型文件路径
# 支持 .pth (PyTorch), .onnx (ONNX), .rknn (RKNN) 格式
MODEL_SINGLE_PATH=models/single_model.pth

# 融合模态模型文件路径
# 支持 .pth (PyTorch), .onnx (ONNX), .rknn (RKNN) 格式
MODEL_FUSION_PATH=models/fusion_model.pth

# ============================================
# 服务器配置
# ============================================

# 服务器监听地址
# 127.0.0.1 - 仅本地访问（开发环境）
# 0.0.0.0   - 允许外部访问（生产环境）
HOST=127.0.0.1

# 服务器监听端口
PORT=8000

# ============================================
# 日志配置（新增）
# ============================================

# 日志级别
# DEBUG    - 详细调试信息（开发环境）
# INFO     - 一般信息（推荐）
# WARNING  - 警告信息
# ERROR    - 错误信息
# CRITICAL - 严重错误
LOG_LEVEL=INFO

# 是否使用 JSON 格式日志
# true  - 输出 JSON 格式，便于 ELK 等日志分析工具采集
# false - 输出人类可读格式（推荐开发环境）
# 默认：false
LOG_JSON_FORMAT=false

# 是否记录请求体（生产环境建议关闭，避免泄露敏感信息）
# true  - 记录 POST/PUT/PATCH 请求的请求体
# false - 不记录请求体
# 默认：false
LOG_REQUEST_BODY=false

# 是否记录响应体（生产环境建议关闭，避免日志过大）
# true  - 记录响应体
# false - 不记录响应体
# 默认：false
LOG_RESPONSE_BODY=false

# 是否启用审计日志
# true  - 启用审计日志，记录关键操作
# false - 禁用审计日志
# 默认：true
AUDIT_LOG_ENABLED=true

# 注意：日志仅输出到文件（logs/目录），不输出到控制台
# 普通日志：logs/{timestamp}.log
# 审计日志：logs/{timestamp}_audit.log（JSON 格式）

# ============================================
# 推理配置
# ============================================

# 推理设备
# cuda - 使用 GPU（需要 CUDA 支持）
# cpu  - 使用 CPU
DEVICE=cuda

# 模型输入尺寸
# 输入图像将被调整为该尺寸（正方形）
# 默认：112
INPUT_SIZE=112

# ============================================
# 认证与安全配置（新增）
# ============================================

# JWT 密钥（生产环境务必修改为随机生成的安全密钥）
# 生成方法：python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=your-secret-key-change-in-production

# JWT Token 过期时间（小时）
# 默认：24 小时
JWT_EXPIRATION_HOURS=24

# 管理员账户（用于 JWT Token 登录，管理激活码）
# 生产环境务必修改为强密码
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-admin-password-change-in-production

# 默认激活码（仅用于开发环境测试）
# 生产环境应通过 /auth/activation-codes 端点创建新的激活码
DEFAULT_ACTIVATION_CODE=ACT-DEV-DEFAULT-KEY

# ============================================
# 调试模式配置（新增）
# ============================================

# 启用调试模式（无需模型文件）
# true  - 使用虚拟推理器，生成随机结果（适合开发测试/前端联调）
# false - 使用真实模型推理（需要模型文件）
# 默认：false
DEBUG_MODE=false

# 单模态图像处理延迟（秒）
# 调试模式下每张图像的模拟处理时间
# 默认：0.5
DEBUG_DELAY_PER_IMAGE=0.5

# 融合模态图像处理延迟（秒）
# 调试模式下每对图像的模拟处理时间
# 默认：0.8
DEBUG_DELAY_PER_PAIR=0.8

# 调试模式失败率（用于测试重试机制）
# 0.0 - 不模拟失败
# 0.3 - 30% 概率模拟失败
# 默认：0.0
DEBUG_FAILURE_RATE=0.0

# ============================================
# 重试配置（新增）
# ============================================

# 是否启用推理失败重试
# true  - 推理失败时自动重试
# false - 失败时直接返回错误
# 默认：true
RETRY_ENABLED=true

# 最大重试次数（包含首次尝试）
# 例如：3 表示首次 + 2 次重试
# 默认：3
RETRY_MAX_ATTEMPTS=3

# 重试基础延迟（秒）
# 每次重试之间的等待时间
# 默认：1.0
RETRY_DELAY_SECONDS=1.0

# 是否启用指数退避
# true  - 延迟时间按指数增长（1s, 2s, 4s...）
# false - 使用固定延迟
# 默认：true
RETRY_EXPONENTIAL_BACKOFF=true

# 最大重试延迟（秒）
# 指数退避时的延迟上限
# 默认：10.0
RETRY_MAX_DELAY_SECONDS=10.0

# ============================================
# 数据库配置（新增）
# ============================================

# 数据库连接 URL
# SQLite: sqlite:///./db/detections.db
# PostgreSQL: postgresql://user:password@host:port/dbname
# 默认：SQLite
DATABASE_URL=sqlite:///./db/detections.db

# ============================================
# 图片存储配置（新增）
# ============================================

# 存储类型
# local - 本地文件存储
# s3    - S3 对象存储（需要配置下方 S3 相关参数）
# 默认：local
STORAGE_TYPE=local

# 本地存储路径
# 图片文件存储的基础目录
# 默认：storage/images
STORAGE_LOCAL_PATH=storage/images

# 存储配额（字节）
# None 表示无限制
# 例如：10737418240 表示 10GB
# 默认：None（无限制）
STORAGE_QUOTA_BYTES=

# 图片保留天数
# 用于手动清理时指定保留天数
# 默认：30 天
STORAGE_RETENTION_DAYS=30

# ============================================
# 图片存储策略配置（方案 A：服务端控制）
# ============================================

# 是否启用自动存储
# true  - 推理完成后根据策略自动保存图片
# false - 不自动保存
# 默认：true
STORAGE_AUTO_SAVE=true

# 存储策略
# never      - 从不存储
# always     - 总是存储（不推荐，会占用大量存储）
# error_only - 只存储错误/失败结果（默认，推荐）
# smart      - 智能策略（按置信度和结果类型采样）
# 默认：error_only
STORAGE_SAVE_STRATEGY=error_only

# 智能策略参数（当 STORAGE_SAVE_STRATEGY=smart 时有效）
# 错误结果保存率（1.0 = 100%）
STORAGE_SAVE_ERROR_RATE=1.0

# 伪造样本保存率（0.1 = 10%，用于模型优化）
STORAGE_SAVE_FAKE_RATE=0.1

# 真实样本保存率（0.01 = 1%，仅少量保存）
STORAGE_SAVE_REAL_RATE=0.01

# 低置信度阈值，低于此值的样本优先保存（用于模型优化）
STORAGE_SAVE_LOW_CONFIDENCE_THRESHOLD=0.6

# 每个任务最多保存图片数（防止单任务占用过多存储）
STORAGE_MAX_PER_TASK=10

# ============================================
# 图片压缩配置（新增）
# ============================================

# 是否启用图片压缩
# true  - 保存前压缩图片，减少存储空间
# false - 保存原始图片
# 默认：true
IMAGE_COMPRESS_ENABLED=true

# 压缩质量（1-100）
# 越高越清晰，文件越大
# 推荐：70-85
# 默认：75
IMAGE_COMPRESS_QUALITY=75

# 压缩器类型
# opencv  - OpenCV 压缩（性能最好，推荐）
# pillow  - Pillow 压缩（备选方案）
# resize  - 调整尺寸 + 压缩（需要配置下方宽高参数）
# 默认：opencv
IMAGE_COMPRESS_TYPE=opencv

# 最大宽度（可选，仅 resize 压缩器有效）
# 0 或空表示不限制
IMAGE_COMPRESS_MAX_WIDTH=

# 最大高度（可选，仅 resize 压缩器有效）
# 0 或空表示不限制
IMAGE_COMPRESS_MAX_HEIGHT=

# ============================================
# S3 对象存储配置（可选，使用本地存储时无需配置）
# ============================================

# S3 桶名
S3_BUCKET=

# AWS 区域
S3_REGION=us-east-1

# S3 兼容端点 URL（用于 MinIO、阿里云 OSS 等）
# 例如：https://oss-cn-hangzhou.aliyuncs.com
S3_ENDPOINT_URL=

# S3 访问密钥
S3_ACCESS_KEY=

# S3 密钥
S3_SECRET_KEY=

# ============================================
# 配置说明
# ============================================
#
# 1. 复制此文件：
#    cp .env.example .env
#
# 2. 修改 .env 中的值
#
# 3. 环境变量优先级高于 .env 文件：
#    export DEVICE=cpu
#    python main.py
#
# 4. 如果 .env 文件不存在，将使用上述默认值
#
# 5. 认证配置说明：
#    - JWT_SECRET_KEY 和 ADMIN_PASSWORD 生产环境务必修改
#    - DEFAULT_ACTIVATION_CODE 仅用于开发测试
#    - API Key 通过激活码换取，不需要预设
#
# 6. 图片存储配置说明：
#    - STORAGE_TYPE=local 时使用本地文件存储
#    - STORAGE_TYPE=s3 时需要配置下方 S3 相关参数
#    - STORAGE_QUOTA_BYTES 为空时表示无限制
#    - 清理过期图片需手动调用 API 端点
#
# ============================================
